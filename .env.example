# Slack — required
SLACK_USER_TOKEN=xoxp-your-user-token

# Slack — optional (Socket Mode acceleration layer)
# SLACK_APP_TOKEN=xapp-your-app-token
# ENABLE_SOCKET_MODE=false

# Email — required (Gmail, QQ Mail, Outlook, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=sender@example.com
SMTP_PASS=your-smtp-password-or-app-password
EMAIL_TO=receiver@example.com

# IMAP — optional (sent mail cleanup)
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USER=sender@example.com
# IMAP_PASS=your-imap-password

# Monitoring — recommended
# HEALTHCHECK_PING_URL=https://hc-ping.com/your-uuid
HEALTH_PORT=8080

# Rules — notification matching
RULES_DIRECT_MESSAGES=true
RULES_USER_IDS=U0123456789
RULES_GROUP_IDS=
RULES_NOTIFY_EDITS=false

# Logging
LOG_LEVEL=info

# State
STATE_DIR=data/state
